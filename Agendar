<script>
  // STATE
  const state = {
    service: null, serviceDuration: null,
    date: null, dateLabel: null,
    time: null,
    currentMonth: new Date().getMonth(),
    currentYear: new Date().getFullYear(),
  };

  // STEP NAVIGATION
  function goStep(n) {
    document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('panel' + n).classList.add('active');
    updateStepsBar(n);
    if (n === 2) renderCalendar();
    if (n === 4) fillSummary();
    const panel = document.getElementById('panel' + n);
    const y = panel.getBoundingClientRect().top + window.scrollY - 80;
    window.scrollTo({top: y, behavior:'smooth'});
  }

  function updateStepsBar(current) {
    for (let i = 1; i <= 4; i++) {
      const dot = document.getElementById('dot' + i);
      const lbl = document.getElementById('lbl' + i);
      if (i < current) { dot.className = 'step-dot done'; dot.textContent = '✓'; }
      else if (i === current) { dot.className = 'step-dot active'; dot.textContent = i; }
      else { dot.className = 'step-dot pending'; dot.textContent = i; }
      if (lbl) lbl.className = i === current ? 'active-label' : '';
    }
    for (let i = 1; i <= 3; i++) {
      const line = document.getElementById('line' + i);
      if (line) line.className = 'step-line' + (i < current ? ' done' : '');
    }
  }

  // STEP 1 — SERVICE
  function selectService(el, name, duration, price, amount) {
    document.querySelectorAll('.service-opt').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    state.service = name;
    state.serviceDuration = duration;
    document.getElementById('btn1').disabled = false;
  }

  // STEP 2 — CALENDAR
  const MONTHS = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

  function changeMonth(dir) {
    state.currentMonth += dir;
    if (state.currentMonth > 11) { state.currentMonth = 0; state.currentYear++; }
    if (state.currentMonth < 0) { state.currentMonth = 11; state.currentYear--; }
    renderCalendar();
  }

  function renderCalendar() {
    const grid = document.getElementById('calGrid');
    document.getElementById('calMonth').textContent = MONTHS[state.currentMonth] + ' ' + state.currentYear;

    // Clear days only
    const headers = grid.querySelectorAll('.cal-day-header');
    grid.innerHTML = '';
    headers.forEach(h => grid.appendChild(h.cloneNode(true)));

    const today = new Date();
    const firstDay = new Date(state.currentYear, state.currentMonth, 1);
    // Monday-first offset
    let offset = firstDay.getDay() - 1;
    if (offset < 0) offset = 6;

    for (let i = 0; i < offset; i++) {
      const empty = document.createElement('div');
      empty.className = 'cal-day empty';
      grid.appendChild(empty);
    }

    const daysInMonth = new Date(state.currentYear, state.currentMonth + 1, 0).getDate();
    for (let d = 1; d <= daysInMonth; d++) {
      const div = document.createElement('div');
      div.textContent = d;
      const thisDate = new Date(state.currentYear, state.currentMonth, d);
      const isSunday = thisDate.getDay() === 0;
      const isPast = thisDate < new Date(today.getFullYear(), today.getMonth(), today.getDate());
      const isToday = thisDate.toDateString() === today.toDateString();

      if (isPast) div.className = 'cal-day past';
      else if (isSunday) div.className = 'cal-day sunday';
      else {
        div.className = 'cal-day available' + (isToday ? ' today' : '');
        div.onclick = () => selectDate(div, d);
      }

      // Mark selected
      if (state.date && state.date.getDate() === d &&
          state.date.getMonth() === state.currentMonth &&
          state.date.getFullYear() === state.currentYear) {
        div.className = 'cal-day selected';
      }

      grid.appendChild(div);
    }
  }

  function selectDate(el, day) {
    document.querySelectorAll('.cal-day.selected').forEach(d => {
      d.className = 'cal-day available';
    });
    el.className = 'cal-day selected';
    state.date = new Date(state.currentYear, state.currentMonth, day);
    const days = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
    state.dateLabel = days[state.date.getDay()] + ' ' + day + ' de ' + MONTHS[state.currentMonth];
    renderSlots();
    document.getElementById('slotsCard').style.display = 'block';
    state.time = null;
    document.getElementById('btn2').disabled = true;
  }

  // SLOTS
  const ALL_SLOTS = ['7:00 AM','7:30 AM','8:00 AM','8:30 AM','9:00 AM','9:30 AM','10:00 AM','10:30 AM','11:00 AM','11:30 AM','1:00 PM','1:30 PM','2:00 PM','2:30 PM','3:00 PM','3:30 PM'];
  const MORNING_SLOTS = ['7:00 AM','7:30 AM','8:00 AM','8:30 AM','9:00 AM','9:30 AM','10:00 AM','10:30 AM','11:00 AM','11:30 AM'];
  const AFTERNOON_SLOTS = ['1:00 PM','1:30 PM','2:00 PM','2:30 PM','3:00 PM','3:30 PM'];

  // Simulate booked maintenances — in production this comes from backend
  // Format: 'YYYY-MM-DD': ['morning', 'afternoon']
  const BOOKED_MAINTENANCE = {};

  function getAvailableSlots() {
    const isMantenimiento = state.service === 'Mantenimiento General';
    const dateKey = state.date ? state.date.toISOString().split('T')[0] : null;
    const bookedBlocks = dateKey ? (BOOKED_MAINTENANCE[dateKey] || []) : [];
    const morningTaken = bookedBlocks.includes('morning');
    const afternoonTaken = bookedBlocks.includes('afternoon');

    if (isMantenimiento) {
      // Only show 7am and 1pm, block if already taken
      return [
        { slot: '7:00 AM', taken: morningTaken, label: morningTaken ? '7:00 AM ✗' : '7:00 AM — Mañana' },
        { slot: '1:00 PM', taken: afternoonTaken, label: afternoonTaken ? '1:00 PM ✗' : '1:00 PM — Tarde' },
      ];
    } else {
      // Regular services — block morning if maintenance at 7am, block afternoon if at 1pm
      return ALL_SLOTS.map(slot => {
        const isMorning = MORNING_SLOTS.includes(slot);
        const isAfternoon = AFTERNOON_SLOTS.includes(slot);
        const taken = (isMorning && morningTaken) || (isAfternoon && afternoonTaken);
        return { slot, taken, label: taken ? slot + ' ✗' : slot };
      });
    }
  }

  function renderSlots() {
    const grid = document.getElementById('slotsGrid');
    grid.innerHTML = '';
    const slots = getAvailableSlots();
    const isMantenimiento = state.service === 'Mantenimiento General';

    if (isMantenimiento) {
      // Show info banner
      const info = document.createElement('div');
      info.style.cssText = 'grid-column:span 3;background:rgba(224,123,42,0.1);border:1px solid rgba(224,123,42,0.3);border-radius:6px;padding:10px 12px;font-size:0.8rem;color:rgba(255,255,255,0.7);margin-bottom:4px;line-height:1.5;';
      info.innerHTML = '🔧 Mantenimiento ocupa medio día. <strong style="color:#e07b2a">Mañana</strong> (7am–12pm) o <strong style="color:#e07b2a">Tarde</strong> (1pm–6pm).';
      grid.appendChild(info);
    }

    slots.forEach(({ slot, taken, label }) => {
      const div = document.createElement('div');
      div.textContent = label;
      if (taken) {
        div.className = 'slot taken';
      } else {
        div.className = 'slot';
        div.onclick = () => selectSlot(div, slot);
      }
      grid.appendChild(div);
    });
  }

  function selectSlot(el, slot) {
    document.querySelectorAll('.slot:not(.taken)').forEach(s => s.classList.remove('selected'));
    el.classList.add('selected');
    state.time = slot;
    document.getElementById('btn2').disabled = false;
  }

  // STEP 3 — VALIDATE
  function validateStep3() {
    const name = document.getElementById('clientName').value.trim();
    const phone = document.getElementById('clientPhone').value.trim();
    const plate = document.getElementById('clientPlate').value.trim();
    const brand = document.getElementById('clientBrand').value.trim();
    const model = document.getElementById('clientModel').value.trim();
    document.getElementById('btn3').disabled = !(name && phone && plate && brand && model);
  }

  // STEP 4 — SUMMARY + WHATSAPP
  function fillSummary() {
    const name = document.getElementById('clientName').value.trim();
    const phone = document.getElementById('clientPhone').value.trim();
    const plate = document.getElementById('clientPlate').value.toUpperCase().trim();
    const brand = document.getElementById('clientBrand').value.trim();
    const model = document.getElementById('clientModel').value.trim();

    document.getElementById('sumService').textContent = state.service + ' (' + state.serviceDuration + ')';
    document.getElementById('sumDate').textContent = state.dateLabel;
    document.getElementById('sumTime').textContent = state.time;
    document.getElementById('sumName').textContent = name;
    document.getElementById('sumMoto').textContent = brand + ' ' + model + ' — ' + plate;

    const msg = encodeURIComponent(
      '🏍️ *SOLICITUD DE CITA — CARMOTORS*\n\n' +
      '📋 *Servicio:* ' + state.service + '\n' +
      '📅 *Fecha:* ' + state.dateLabel + '\n' +
      '🕐 *Hora:* ' + state.time + '\n\n' +
      '👤 *Cliente:* ' + name + '\n' +
      '📞 *Teléfono:* ' + phone + '\n' +
      '🏍️ *Moto:* ' + brand + ' ' + model + ' (' + plate + ')\n\n' +
      '💚 *Anticipo enviado por Nequi: $15.300*\n' +
      'Adjunto comprobante de pago para confirmar mi cita.'
    );
    document.getElementById('btnWhatsapp').href = 'https://wa.me/573113919658?text=' + msg;
  }

  function markDone() {
    setTimeout(() => goStep(5), 500);
  }

  // INIT
  renderCalendar();
</script>
